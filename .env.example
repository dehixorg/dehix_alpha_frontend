# ============================================
# ENVIRONMENT CONFIGURATION TEMPLATE
# ============================================
# 
# Copy this file to .env.local and fill in your values
# Command: cp .env.example .env.local
#
# DO NOT commit .env.local to git!
# It's already in .gitignore for security


#
# ============================================
# FIREBASE CONFIGURATION
# ============================================
NEXT_PUBLIC__API_KEY="your_firebase_api_key_here"
NEXT_PUBLIC__AUTH_DOMAIN="your_firebase_auth_domain_here"
NEXT_PUBLIC__DATABASE_URL="your_firebase_database_url_here"
NEXT_PUBLIC__PROJECT_ID="your_firebase_project_id_here"
NEXT_PUBLIC__STORAGE_BUCKET="your_firebase_storage_bucket_here"
NEXT_PUBLIC__MESSAGING_SENDER_ID="your_firebase_messaging_sender_id_here"
NEXT_PUBLIC__APP_ID="your_firebase_app_id_here"

# ============================================
# BACKEND API CONFIGURATION
# ============================================
# Set this to your backend API URL
# For local development: http://localhost:3001
# For staging: https://devapi.dehix.org/
NEXT_PUBLIC__BASE_URL="http://localhost:8080/"

# ============================================
# WEB3 / BLOCKCHAIN CONFIGURATION
# ============================================

# Wallet Connect Project ID (required for wallet connection)
# Get it from: https://cloud.walletconnect.com/
NEXT_PUBLIC_WALLET_CONNECT_PROJECT_ID="your_walletconnect_project_id_here"

# Freelancer Contract Address (Polygon Amoy Testnet)
# Default if not set in .env.local: 0x1f04977be437ade69ad867ecf8bfc3b3ae7abcc4
# ✅ RECOMMENDED: Set these values (or edit src/config/contracts/contractConfig.ts)
NEXT_PUBLIC_FREELANCER_CONTRACT_POLYGON_AMOY="0x1f04977be437ade69ad867ecf8bfc3b3ae7abcc4"

# Soulbound Token (SBT) Contract Address (Polygon Amoy Testnet)
# Default if not set in .env.local: 0xac0484c2361504ae8f71e95a149f7a81cd7bdda5
# ✅ RECOMMENDED: Set these values (or edit src/config/contracts/contractConfig.ts)
NEXT_PUBLIC_SBT_CONTRACT_POLYGON_AMOY="0xac0484c2361504ae8f71e95a149f7a81cd7bdda5"

# Pinata (optional, used for NDA JSON uploads)
# Option A (recommended): Pinata JWT
# NEXT_PUBLIC_PINATA_JWT="your_pinata_jwt_here"
# Option B: API key + secret
# NEXT_PUBLIC_PINATA_API_KEY="your_pinata_api_key_here"
# NEXT_PUBLIC_PINATA_API_SECRET="your_pinata_api_secret_here"

# ============================================
# OTHER CONFIGURATION (OPTIONAL)
# ============================================

# S3 Bucket URL for file uploads (if using S3)
# NEXT_PUBLIC_S3_BUCKET_URL="your_s3_bucket_url"

# HTTP Retry Configuration (ms)
# NEXT_PUBLIC_HTTP_MAX_RETRIES=2
# NEXT_PUBLIC_HTTP_RETRY_BASE_DELAY_MS=300
# NEXT_PUBLIC_HTTP_RETRY_MAX_DELAY_MS=3000

# App-specific costs (in tokens/wei)
# NEXT_PUBLIC__APP_HIRE_TALENT_COST="0"
# NEXT_PUBLIC__APP_PROJECT_CREATION_COST="0"

# ============================================
# SETUP INSTRUCTIONS
# ============================================
#
# 1. Copy this file:
#    cp .env.example .env.local
#
# 2. Fill in required values:
#    - Firebase configuration (from Firebase console)
#    - NEXT_PUBLIC__BASE_URL (your API server)
#    - NEXT_PUBLIC_WALLET_CONNECT_PROJECT_ID (from WalletConnect)
#
# 3. Save and restart your development server
#
# 4. Troubleshooting 404 errors:
#    - Check NEXT_PUBLIC__BASE_URL points to correct API
#    - Verify API backend is running
#    - Check browser console for actual API URL being used
#    - Clear browser cache and restart dev server
#
# 5. Troubleshooting wallet not connecting:
#    - Verify NEXT_PUBLIC_WALLET_CONNECT_PROJECT_ID is set
#    - Check that Polygon Amoy testnet is available in your wallet
#    - Ensure you have testnet MATIC/POL for gas fees
#
# ============================================